{
  "name": "atlas-insight-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@types/cytoscape": ">=3.21.9",
    "@types/dompurify": ">=3.2.0",
    "axios": ">=1.16.1",
    "chart.js": ">=4.5.1",
    "cytoscape": ">=3.33.4",
    "cytoscape-fcose": ">=2.2.0",
    "dompurify": ">=3.4.8",
    "marked": ">=18.0.4",
    "pinia": ">=3.0.4",
    "vue": ">=3.5.35",
    "vue-chartjs": ">=5.3.3",
    "vue-router": ">=4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": ">=5.2.4",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": ">=2.4.6",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": ">=26.0.0",
    "sass": ">=1.100.0",
    "typescript": ">=5.6.3",
    "vite": ">=6.4.2",
    "vitest": "^4.1.8",
    "vue-tsc": ">=2.2.12"
  }
