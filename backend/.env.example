# Application
# Dev:  config.settings.development
# Prod: config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Keep False when behind nginx/Cloudflare (they handle TLS). Set True only if Django is
# directly internet-facing without a terminating proxy — otherwise Django redirect-loops.
SECURE_SSL_REDIRECT=False

# Site
SITE_NAME=Atlas Insight

# Database (matches docker-compose defaults)
POSTGRES_DB=atlas_insight
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=4503

# Redis / Celery
CELERY_BROKER_URL=redis://localhost:4502/0
CELERY_RESULT_BACKEND=redis://localhost:4502/1

# Optional: higher GitHub API rate limits (5000/hr vs 60/hr)
GITHUB_TOKEN=
# Optional: URL of a public repo to feature on the home page (must already be analyzed)
FEATURED_REPO_URL=
# Local cache dir for cloned repos (relative to repo root)
REPO_CACHE_DIR=_running/repo_cache
# Days since last fetch before a repo is marked stale (triggers re-analysis on next submit)
STALE_AFTER_DAYS=7
# Days since last fetch before the local clone cache is deleted to reclaim disk
# Must be >= STALE_AFTER_DAYS. Result JSON in DB is unaffected; re-analysis re-clones.
EVICT_AFTER_DAYS=30
# How many completed AnalysisRuns to keep per repo (oldest deleted first)
RUNS_TO_KEEP_PER_REPO=10
# Days to retain rotated log backup files (django.log.1, celery.log.2, etc.)
LOG_RETENTION_DAYS=30
# Log level for app and celery loggers (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# GitHub OAuth (https://github.com/settings/applications/new)
# Callback URL: http://localhost:4500/accounts/github/login/callback/
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Frontend URL (used for post-login redirect)
FRONTEND_URL=http://localhost:4501

# Cloudflare Tunnel
# Get token from: https://one.dash.cloudflare.com/ → Zero Trust → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# Sentry / GlitchTip error tracking — written automatically by make start (via setup-glitchtip).
# Leave blank to disable. Do not edit manually; make start will overwrite it.
SENTRY_DSN=
# Required when running GlitchTip (set a strong random string in production)
GLITCHTIP_SECRET_KEY=
# Public URL GlitchTip uses for links in emails and the UI
GLITCHTIP_DOMAIN=https://glitch.dsyndicate.dev
# GlitchTip CSRF trusted origins — must include every scheme+host users access GlitchTip from.
# Comma-separated, no trailing slash.
GLITCHTIP_CSRF_TRUSTED_ORIGINS=https://glitch.dsyndicate.dev,http://localhost:4505
# GlitchTip uses email/password only (no GitHub OAuth). Create first admin with:
#   make glitchtip-create-admin EMAIL=you@example.com PASSWORD=yourpassword
# Add users later via GlitchTip UI: Organizations → Members → Invite.
# Optional: comma-separated GlitchTip project names to auto-provision on startup
# GLITCHTIP_PROJECTS=Backend,Frontend
# Optional: project name to use when writing SENTRY_DSN back to backend/.env
# GLITCHTIP_PRIMARY_PROJECT=Backend
