# Application
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Site
SITE_NAME=Atlas Insight

# Database (matches docker-compose defaults)
POSTGRES_DB=atlas_insight
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=4503

# Redis / Celery
CELERY_BROKER_URL=redis://localhost:4502/0
CELERY_RESULT_BACKEND=redis://localhost:4502/1

# Optional: higher GitHub API rate limits (5000/hr vs 60/hr)
GITHUB_TOKEN=
# Local cache dir for cloned repos (relative to repo root)
REPO_CACHE_DIR=_running/repo_cache
# Log level for app and celery loggers (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
