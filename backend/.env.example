# Application
# Dev:  config.settings.development
# Prod: config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Keep False when behind nginx/Cloudflare (they handle TLS). Set True only if Django is
# directly internet-facing without a terminating proxy — otherwise Django redirect-loops.
SECURE_SSL_REDIRECT=False

# Site
SITE_NAME=Atlas Insight

# Database (matches docker-compose defaults for bare-process dev)
# When running via make docker-up, docker-compose overrides POSTGRES_HOST=postgres and POSTGRES_PORT=5432.
POSTGRES_DB=atlas_insight
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=4503

# Redis / Celery
CELERY_BROKER_URL=redis://localhost:4502/0
CELERY_RESULT_BACKEND=redis://localhost:4502/1

# Optional: higher GitHub API rate limits (5000/hr vs 60/hr)
GITHUB_TOKEN=
# Optional: URL of a public repo to feature on the home page (must already be analyzed)
FEATURED_REPO_URL=
# Local cache dir for cloned repos (relative to repo root)
REPO_CACHE_DIR=_running/repo_cache
# Days since last fetch before a repo is marked stale (triggers re-analysis on next submit)
STALE_AFTER_DAYS=7
# Hours since last fetch before the local clone cache is deleted to reclaim disk.
# Result JSON in DB is unaffected; re-analysis re-clones on next request.
EVICT_AFTER_HOURS=24
# Hard disk cap for repo_cache in gigabytes. When exceeded, LRU clones are removed
# (oldest last_fetched_at first) until total drops below the limit.
MAX_CACHE_GB=10
# How many completed AnalysisRuns to keep per repo (oldest deleted first)
RUNS_TO_KEEP_PER_REPO=10
# Days to retain rotated log backup files (django.log.1, celery.log.2, etc.)
LOG_RETENTION_DAYS=30
# Log level for app and celery loggers (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
# Write logs to _running/logs/<service>.log (truncated on each start).
# True locally for file logs regardless of DEBUG setting. False in prod Docker (use stdout).
LOG_TO_FILE=False

# GitHub inbound webhooks — required in production (DEBUG=False). Skipped in dev when unset.
# python3 -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=

# Fernet key for encrypting stored GitHub PATs — required in production.
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# GitHub OAuth (https://github.com/settings/applications/new)
# Callback URL: http://localhost:4500/accounts/github/login/callback/
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public URLs (used for OAuth callbacks and post-login redirect)
FRONTEND_URL=http://localhost:4501
BACKEND_URL=http://localhost:4500

# Cloudflare Tunnel
# Get token from: https://one.dash.cloudflare.com/ → Zero Trust → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# Error tracking — optional. Set a Sentry-compatible DSN to enable SDK error capture.
# Leave blank to rely on console/file logs only.
# SENTRY_DSN=
